# ============================================================================
# my-app — variáveis de ambiente
# ============================================================================
# Copie este arquivo pra .env e preencha com os valores locais.
# Nunca committe .env (já coberto por .gitignore).
# Referências de seção apontam pra Obsidian/my-app/Neuronios/Projetos/Backend Plan.md
# ============================================================================

# ----------------------------------------------------------------------------
# Database (Backend Plan §1.2 + §7) — passo 1
# ----------------------------------------------------------------------------
# Postgres local via docker-compose. Porta 5433 evita conflito com instalações
# nativas. Usuário/senha/banco coincidem com defaults do docker-compose.yml.
DATABASE_URL="postgresql://myapp:myapp@localhost:5433/myapp?schema=public"

# Overrides opcionais do docker-compose (só se quiser mudar credenciais/porta)
# POSTGRES_USER=myapp
# POSTGRES_PASSWORD=myapp
# POSTGRES_DB=myapp
# POSTGRES_PORT=5433

# ----------------------------------------------------------------------------
# App (Backend Plan §7) — usado em URLs de webhook, invite, reset
# ----------------------------------------------------------------------------
APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Seed (Backend Plan §2 — passo 2) — admin default criado por prisma db seed
# ----------------------------------------------------------------------------
# Se ausentes em dev, cai num fallback (admin@local.test / admin123).
# Em production, ambas são obrigatórias — o script aborta caso não estejam setadas.
# SEED_ADMIN_EMAIL="admin@local.test"
# SEED_ADMIN_PASSWORD="admin123"

# ----------------------------------------------------------------------------
# Auth.js v5 (Backend Plan §3) — passo 3
# ----------------------------------------------------------------------------
# Nomes AUTH_* são a convenção da Auth.js v5 (não mais NEXTAUTH_*).
# Gere AUTH_SECRET com: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Email — Resend (Backend Plan §1.5) — passo 4
# ----------------------------------------------------------------------------
# Em dev, se RESEND_API_KEY estiver ausente, lib/email.ts imprime o email no
# console (útil pra testar fluxos de convite/reset sem conta Resend).
# Em production, setar ambas. Obter chave em https://resend.com/api-keys.
# RESEND_FROM_EMAIL precisa de domínio verificado; sem ele, só dá pra mandar
# pra o email da conta Resend. Default: "Adrilo <onboarding@resend.dev>".
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="Adrilo <no-reply@seu-dominio.com>"

# ----------------------------------------------------------------------------
# UazApi — WhatsApp (Backend Plan §10.4 + Neuronios/Referencias/UazApi.md) — passo 7
# ----------------------------------------------------------------------------
# Admin token do servidor UazApi (usado pra criar instâncias programaticamente)
# UAZAPI_ADMIN_TOKEN=""
# UAZAPI_DEFAULT_SUBDOMAIN=""

# Tokens de instância (seed inicial — depois gerenciado via UI)
# UAZAPI_TOKEN=""
# UAZAPI_TOKEN2=""
# UAZAPI_TOKEN3=""

# ----------------------------------------------------------------------------
# File storage — Cloudflare R2 (Backend Plan §1.4) — passo 14
# ----------------------------------------------------------------------------
# Obrigatório para upload de mídia em /conversas e /respostas-rapidas.
# Criar bucket em https://dash.cloudflare.com → R2 → Create bucket.
# API token em R2 → Manage API Tokens → Object Read & Write.
# R2_PUBLIC_URL = habilitar "R2.dev subdomain" no bucket → copiar URL gerada.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ----------------------------------------------------------------------------
# Observabilidade (Backend Plan §1.7) — passo 18
# ----------------------------------------------------------------------------
# SENTRY_DSN=""
